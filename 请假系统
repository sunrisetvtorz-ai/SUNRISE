    }

    function findDetailTimeRows() {
      var rows = Array.prototype.slice.call(document.querySelectorAll(".detialBox___1X_BF .detialLine___3dSsI"));
      var timeRows = rows.filter(function (row) {
        var valueNode = row.querySelector("span");
        return valueNode && /^\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}$/.test(valueNode.textContent.trim());
      });
      return {
        startRow: timeRows[0] || null,
        endRow: timeRows[1] || null,
        durationRow: rows[5] || null
      };
    }

    function createEditor(typeNode, reasonNode, applicantNode, reviewerNode, startNode, endNode, durationNode) {
      if (document.getElementById("tiny-time-editor")) return;

      var editor = document.createElement("div");
      editor.id = "tiny-time-editor";
      editor.style.cssText = [
        "display:none",
        "position:fixed",
        "right:16px",
        "bottom:20px",
        "z-index:9999",
        "width:220px",
        "padding:10px",
        "border-radius:10px",
        "background:rgba(255,255,255,0.98)",
        "box-shadow:0 8px 24px rgba(0,0,0,0.12)",
        "border:1px solid #e9edf2",
        "font-family:-apple-system,BlinkMacSystemFont,'PingFang SC','Microsoft YaHei',sans-serif"
      ].join(";");

      var title = document.createElement("div");
      title.textContent = "修改时间";
      title.style.cssText = "font-size:12px;color:#7f8a99;margin-bottom:8px;";

      var typeInput = document.createElement("input");
      typeInput.type = "text";
      typeInput.value = typeNode.textContent.trim();
      typeInput.placeholder = "请输入请假类型";
      typeInput.style.cssText = "width:100%;font-size:12px;padding:6px 8px;border:1px solid #dde3ec;border-radius:6px;box-sizing:border-box;margin-bottom:8px;";

      var reasonInput = document.createElement("input");
      reasonInput.type = "text";
      reasonInput.value = reasonNode.textContent.trim();
      reasonInput.placeholder = "请输入请假理由";
      reasonInput.style.cssText = "width:100%;font-size:12px;padding:6px 8px;border:1px solid #dde3ec;border-radius:6px;box-sizing:border-box;margin-bottom:8px;";

      var applicantInput = document.createElement("input");
      applicantInput.type = "text";
      applicantInput.value = applicantNode.textContent.trim();
      applicantInput.placeholder = "请输入申请人姓名";
      applicantInput.style.cssText = "width:100%;font-size:12px;padding:6px 8px;border:1px solid #dde3ec;border-radius:6px;box-sizing:border-box;margin-bottom:8px;";

      var reviewerInput = document.createElement("input");
      reviewerInput.type = "text";
      reviewerInput.value = reviewerNode.textContent.trim();
      reviewerInput.placeholder = "请输入审核人姓名";
      reviewerInput.style.cssText = "width:100%;font-size:12px;padding:6px 8px;border:1px solid #dde3ec;border-radius:6px;box-sizing:border-box;margin-bottom:8px;";

      var startInput = document.createElement("input");
      startInput.type = "datetime-local";
      startInput.value = toDatetimeLocal(startNode.textContent.trim());
      startInput.style.cssText = "width:100%;font-size:12px;padding:6px 8px;border:1px solid #dde3ec;border-radius:6px;box-sizing:border-box;margin-bottom:8px;";

      var endInput = document.createElement("input");
      endInput.type = "datetime-local";
      endInput.value = toDatetimeLocal(endNode.textContent.trim());
      endInput.style.cssText = "width:100%;font-size:12px;padding:6px 8px;border:1px solid #dde3ec;border-radius:6px;box-sizing:border-box;margin-bottom:8px;";

      var actions = document.createElement("div");
      actions.style.cssText = "display:flex;justify-content:flex-end;gap:8px;";

      var cancelBtn = document.createElement("button");
      cancelBtn.type = "button";
      cancelBtn.textContent = "取消";
      cancelBtn.style.cssText = "font-size:12px;color:#8b95a3;background:none;border:none;padding:2px 4px;";

      var okBtn = document.createElement("button");
      okBtn.type = "button";
      okBtn.textContent = "确定";
      okBtn.style.cssText = "font-size:12px;color:#397ef0;background:none;border:none;padding:2px 4px;";

      cancelBtn.addEventListener("click", function () {
        editor.style.display = "none";
      });

      okBtn.addEventListener("click", function () {
        typeNode.textContent = typeInput.value.trim();
        reasonNode.textContent = reasonInput.value.trim();
        applicantNode.textContent = applicantInput.value.trim();
        reviewerNode.textContent = reviewerInput.value.trim();
        var startText = fromDatetimeLocal(startInput.value);
        var endText = fromDatetimeLocal(endInput.value);
        if (!startText || !endText) return;
        startNode.textContent = startText;
        endNode.textContent = endText;
        if (durationNode) {
          var durationValueNode = durationNode.querySelector("span");
          if (durationValueNode) {
            var durationText = calcDuration(startText, endText);
            if (durationText) durationValueNode.textContent = durationText;
          }
        }
        editor.style.display = "none";
      });

      actions.appendChild(cancelBtn);
      actions.appendChild(okBtn);
      editor.appendChild(title);
      editor.appendChild(typeInput);
      editor.appendChild(reasonInput);
      editor.appendChild(applicantInput);
      editor.appendChild(reviewerInput);
      editor.appendChild(startInput);
      editor.appendChild(endInput);
      editor.appendChild(actions);
      document.body.appendChild(editor);

      return editor;
    }

    function setupTinyButton() {
      var rows = findDetailTimeRows();
      if (!rows.startRow || !rows.endRow) return;
      var detailRows = Array.prototype.slice.call(document.querySelectorAll(".detialBox___1X_BF .detialLine___3dSsI"));
      var typeRow = detailRows[0] || null;
      var reasonRow = detailRows[8] || null;
      var stepNames = document.querySelectorAll(".grayText___1PS9X");
      var startValueNode = rows.startRow.querySelector("span");
      var endValueNode = rows.endRow.querySelector("span");
      var typeValueNode = typeRow ? typeRow.querySelector("span") : null;
      var reasonValueNode = reasonRow ? reasonRow.querySelector("span") : null;
      var applicantNode = stepNames[0] || null;
      var reviewerNode = stepNames[1] || null;
      if (!startValueNode || !endValueNode || !typeValueNode || !reasonValueNode || !applicantNode || !reviewerNode) return;

      var endStepTitle = Array.prototype.slice.call(document.querySelectorAll(".step_title___3yKU2")).find(function (node) {
        return /缁撴潫|结束/.test(node.textContent);
      });
      if (!endStepTitle || document.getElementById("tiny-time-edit-btn")) return;

      var editor = createEditor(typeValueNode, reasonValueNode, applicantNode, reviewerNode, startValueNode, endValueNode, rows.durationRow);
      var btn = document.createElement("button");
      btn.id = "tiny-time-edit-btn";
      btn.type = "button";
      btn.textContent = "改";
      btn.style.cssText = [
        "margin-left:8px",
        "padding:0 4px",
        "height:18px",
        "line-height:18px",
        "font-size:10px",
        "color:#b5bcc7",
        "background:transparent",
        "border:1px solid #e4e8ef",
        "border-radius:9px",
        "vertical-align:middle"
      ].join(";");

      btn.addEventListener("click", function (event) {
        event.stopPropagation();
        if (!editor) return;
        var textInputs = editor.querySelectorAll("input[type='text']");
        var timeInputs = editor.querySelectorAll("input[type='datetime-local']");
        textInputs[0].value = typeValueNode.textContent.trim();
        textInputs[1].value = reasonValueNode.textContent.trim();
        textInputs[2].value = applicantNode.textContent.trim();
        textInputs[3].value = reviewerNode.textContent.trim();
        var startInput = timeInputs[0];
        var endInput = timeInputs[1];
        startInput.value = toDatetimeLocal(startValueNode.textContent.trim());
        endInput.value = toDatetimeLocal(endValueNode.textContent.trim());
        editor.style.display = editor.style.display === "block" ? "none" : "block";
      });

      endStepTitle.appendChild(btn);

      document.addEventListener("click", function (event) {
        if (!editor || editor.style.display !== "block") return;
        if (editor.contains(event.target) || btn.contains(event.target)) return;
        editor.style.display = "none";
      });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setupTinyButton);
    } else {
      setupTinyButton();
    }
  })();
</script></body></html>
